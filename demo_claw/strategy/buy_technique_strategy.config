# 买入策略配置文件 - 基于三维评分系统

# ========== 评分权重 ==========
# 量价形态权重
price_volume_weight,1.0

# 基本面权重
fundamental_weight,0.0

# ========== 技术指标参数 ==========
# 均线周期（用于判断趋势方向，默认20，可选30/60等）
ma_period,30

# ========== 买入阈值 ==========
# 综合分买入阈值（>=此分数才买入）
buy_score_threshold,8.5

# ========== 选股范围 ==========
# 行业条件（逗号分隔，空表示全市场）
industry,创业板
