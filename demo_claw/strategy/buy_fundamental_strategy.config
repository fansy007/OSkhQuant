# 买入策略配置文件

# ========== 行业条件 ==========
industry,创业板

# ========== 技术指标 ==========
# 换手率: 天数, 换手率阈值, 日均阈值
turnover,10,5,2

# ========== 财务指标 - 静态条件 ==========
# 格式: s_字段,比较符,值 (只拿Q4数据，与固定值比较)
s_revenue,>,100000000
s_oper_profit,>,10000000
s_net_profit_incl_min_int_inc_after,>,100000000

# ========== 财务指标 - 动态条件 ==========
# 格式: d_字段,比较符,N (最新一期与前N年同期比较，连续N年增长)
d_revenue,>,2
d_net_profit_incl_min_int_inc_after,>,2
adjusted_net_profit_rate,>,2
