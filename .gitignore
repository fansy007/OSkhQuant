xtquant
# --------------------
# Python 特定忽略规则
# --------------------

# 字节码编译/优化/DLL 文件
__pycache__/           # Python 字节代码缓存目录
*.py[cod]              # 具体的字节码文件后缀
*$py.class             # 其他形式的字节码文件

# C 扩展
*.so                   # 编译后的 C 扩展模块

# 分发 / 打包 / 发布文件
.Python
build/                 # 构建过程中生成的临时目录
develop-eggs/
dist/                  # 打包后生成的分发文件目录
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/           # 包元信息
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# 安装器日志
pip-log.txt
pip-delete-this-directory.txt

# 单元测试 / 覆盖率报告
htmlcov/
.tox/                 # tox 虚拟环境目录
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/        # Pytest 缓存
cover/

# 虚拟环境（务必忽略！）
.env                  # 环境变量文件（常含敏感信息）
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# 特定框架文件
# Django
*.log
local_settings.py     # 本地 Django 配置
db.sqlite3            # 开发用的 SQLite 数据库
db.sqlite3-journal

# Flask
instance/
.webassets-cache

# Scrapy
.scrapy

# Jupyter Notebook
.ipynb_checkpoints    # Jupyter 检查点

# IPython
profile_default/
ipython_config.py

# 类型检查器
.mypy_cache/          # MyPy 缓存
.dmypy.json
dmypy.json
.pyre/                # Pyre 类型检查器
.pytype/              # Pytype 分析器

# --------------------
# 操作系统特定文件
# --------------------

# macOS
.DS_Store             # macOS 目录自定义属性文件
.AppleDouble
.LSOverride

# --------------------
# IDE 和编辑器文件
# --------------------

# PyCharm
.idea/                # PyCharm 项目配置

# VS Code
.vscode/              # VS Code 工作区设置
*.code-workspace

# --------------------
# 项目自定义规则
# --------------------
# 你可以在此添加项目特定的忽略规则
# 例如：logs/、uploads/、本地配置文件等